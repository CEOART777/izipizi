@page
@model практика_2._0.Pages.TeacherModel
@{
    ViewData["Title"] = "Проверка";
}

<section class="panel">
    <h1 class="h2 mb-2">Проверка домашних заданий</h1>
    <p class="text-muted mb-3">Ваши курсы и студенты, которые отправили работы.</p>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (Model.Courses.Count == 0)
    {
        <div class="alert alert-info mb-0">Вам пока не назначены курсы. Администратор должен указать вас в поле <code>teacher_user_id</code> у курса.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var c in Model.Courses)
            {
                <div class="col-lg-6">
                    <div class="panel h-100">
                        <h2 class="h5 mb-1">@c.Course_name</h2>
                        <div class="text-muted small mb-2">⭐ @c.rating.ToString("0.0") · Цена: @c.price.ToString("0.##") ₽</div>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-primary" asp-page="/TeacherCourse" asp-route-courseId="@c.ID_curs">Открыть курс</a>
                            <a class="btn btn-outline-secondary" asp-page="/Course" asp-route-courseId="@c.ID_curs">Страница курса</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>

