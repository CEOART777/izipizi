@page
@model практика_2._0.Pages.ProfileSecurityModel
@{
    ViewData["Title"] = "Безопасность";
}

<section class="mb-3">
    <h1 class="display-5 fw-bold">Безопасность аккаунта</h1>
    <p class="text-muted">Смените пароль и управляйте безопасностью профиля.</p>
</section>

@if (Model.User is not null)
{
    @await Html.PartialAsync("_ProfileSectionNav", new практика_2._0.Models.ProfileSectionNavModel
    {
        Active = "security",
        UserId = Model.User.ID_user,
        BonusBalance = Model.User.balanse_coins,
        RewardCoins = Model.User.reward_coins
    })
}

<section class="panel" style="max-width:760px;">
    <h3 class="mb-3">Смена пароля</h3>
    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success">@Model.SuccessMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }
    <form method="post">
        <input type="hidden" name="userId" value="@Model.User?.ID_user" />
        <div class="row g-3">
            <div class="col-12">
                <label class="form-label">Текущий пароль</label>
                <input asp-for="Input.CurrentPassword" type="password" class="form-control form-control-lg" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Новый пароль</label>
                <input asp-for="Input.NewPassword" type="password" class="form-control form-control-lg" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Повторите пароль</label>
                <input asp-for="Input.ConfirmPassword" type="password" class="form-control form-control-lg" />
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary">Обновить пароль</button>
            </div>
        </div>
    </form>
</section>
