@model практика_2._0.Models.ProfileSectionNavModel
@{
    var uid = Model.UserId;
    var bonus = Model.BonusBalance ?? 0;
    var rub = Model.RubBalance ?? 0m;
}
<div class="panel profile-section-head mb-3">
    <div class="row align-items-center g-3">
        <div class="col-lg-5">
            <div class="d-flex flex-wrap gap-4 align-items-end">
                <div>
                    <div class="text-muted small mb-0">Бонусные баллы</div>
                    <div class="display-6 text-primary fw-bold lh-1 mb-0">@bonus</div>
                    <div class="text-muted small">доступно к списанию</div>
                </div>
                <div>
                    <div class="text-muted small mb-0">Баланс (руб)</div>
                    <div class="fs-2 fw-semibold lh-1 mb-0">@rub.ToString("0.##")</div>
                    <div class="text-muted small">возвраты от админа</div>
                </div>
                <div>
                    <div class="text-muted small mb-0">Награды</div>
                    <div class="fs-2 text-success fw-semibold lh-1 mb-0">@Model.RewardCoins</div>
                    <div class="text-muted small">монеты за активность</div>
                </div>
            </div>
        </div>
        <div class="col-lg-7">
            <p class="text-muted small mb-2 d-lg-none">Разделы профиля</p>
            <div class="d-flex flex-wrap gap-2 justify-content-lg-end">
                <a class="tab-chip text-decoration-none @(Model.Active == "info" ? "tab-chip-active" : null)"
                   asp-page="/UserProfile" asp-route-userId="@uid">Личная информация</a>
                <a class="tab-chip text-decoration-none @(Model.Active == "security" ? "tab-chip-active" : null)"
                   asp-page="/ProfileSecurity" asp-route-userId="@uid">Безопасность</a>
                <a class="tab-chip text-decoration-none @(Model.Active == "notifications" ? "tab-chip-active" : null)"
                   asp-page="/ProfileNotifications" asp-route-userId="@uid">Уведомления</a>
            </div>
        </div>
    </div>
</div>
