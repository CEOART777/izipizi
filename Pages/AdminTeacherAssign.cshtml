@page
@model практика_2._0.Pages.AdminTeacherAssignModel
@{
    ViewData["Title"] = "Админ — назначение учителя на курс";
}

<section class="admin-shell">
    <aside class="admin-side">
        <div class="admin-brand">Admin Panel</div>
        <nav class="admin-nav">
            <a class="admin-link" asp-page="/Admin">Дашборд</a>
            <a class="admin-link active" asp-page="/AdminUsers">Пользователи</a>
            <a class="admin-link" asp-page="/AdminCourses">Курсы</a>
            <a class="admin-link" asp-page="/AdminFinance">Финансы</a>
            <a class="admin-link" asp-page="/AdminRefunds">Отписки</a>
        </nav>
    </aside>

    <div class="admin-main">
        <div class="admin-top">
            <div>
                <h1 class="admin-title mb-1">Назначение учителя на курс</h1>
                <div class="text-muted">Выберите курс, который будет вести учитель</div>
            </div>
            <div class="d-flex gap-2">
                <a class="btn btn-outline-secondary" asp-page="/AdminUsers">Назад</a>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="alert alert-success">@Model.SuccessMessage</div>
        }

        <div class="admin-panel">
            @if (Model.Teacher is null)
            {
                <div class="alert alert-warning mb-0">Пользователь не найден.</div>
            }
            else
            {
                <div class="mb-3">
                    <div class="fw-semibold">@Model.Teacher.full_name</div>
                    <div class="text-muted small">@Model.Teacher.email · роль: @Model.Teacher.role</div>
                </div>

                <form method="post" class="mb-3">
                    <input type="hidden" name="teacherId" value="@Model.Teacher.ID_user" />
                    <button class="btn btn-outline-warning" type="submit" asp-page-handler="UnassignAll"
                            onclick="return confirm('Снять учителя со всех курсов?');">
                        Снять со всех курсов
                    </button>
                </form>

                <div class="table-responsive">
                    <table class="table table-dark table-sm align-middle mb-0">
                        <thead>
                        <tr>
                            <th>Курс</th>
                            <th class="text-end">Цена</th>
                            <th class="text-end">Текущий учитель</th>
                            <th></th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var c in Model.Courses)
                        {
                            var hasTeacher = Model.CourseTeacherMap.TryGetValue(c.ID_curs, out var currentTeacherId) && currentTeacherId > 0;
                            var assignedToThis = (hasTeacher && currentTeacherId == Model.Teacher.ID_user) || Model.AssignedCourseIds.Contains(c.ID_curs);
                            <tr>
                                <td>
                                    <div class="fw-semibold">@c.Course_name</div>
                                    <div class="text-muted small">ID: @c.ID_curs</div>
                                </td>
                                <td class="text-end">@c.price.ToString("0.##") ₽</td>
                                <td class="text-end">
                                    <span class="badge @(hasTeacher ? "text-bg-success" : "text-bg-secondary")">
                                        @(hasTeacher ? currentTeacherId.ToString() : "не назначен")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <form method="post" class="d-inline">
                                        <input type="hidden" name="teacherId" value="@Model.Teacher.ID_user" />
                                        <input type="hidden" name="courseId" value="@c.ID_curs" />
                                        @if (!assignedToThis)
                                        {
                                            <button class="btn btn-sm btn-outline-light" type="submit" asp-page-handler="Assign"
                                                    onclick="return confirm('Назначить этого учителя на курс?');">
                                                Назначить
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-warning" type="submit" asp-page-handler="Unassign"
                                                    onclick="return confirm('Снять учителя с курса?');">
                                                Снять
                                            </button>
                                        }
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>

