@page
@model практика_2._0.Pages.AdminLessonCreateModel
@{
    ViewData["Title"] = "Админ — добавить урок";
}

<section class="admin-shell">
    <aside class="admin-side">
        <div class="admin-brand">Admin Panel</div>
        <nav class="admin-nav">
            <a class="admin-link" asp-page="/Admin">Дашборд</a>
            <a class="admin-link" asp-page="/AdminUsers">Пользователи</a>
            <a class="admin-link active" asp-page="/AdminCourses">Курсы</a>
            <a class="admin-link" asp-page="/AdminFinance">Финансы</a>
            <a class="admin-link" asp-page="/AdminRefunds">Отписки</a>
        </nav>
    </aside>

    <div class="admin-main">
        <div class="admin-top">
            <div>
                <h1 class="admin-title mb-1">Добавить урок</h1>
                <div class="text-muted">Курс: @Model.CourseName</div>
            </div>
            <div class="d-flex gap-2">
                <a class="btn btn-outline-secondary" asp-page="/AdminCourses">Назад</a>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="alert alert-success">@Model.SuccessMessage</div>
        }

        <div class="admin-panel" style="max-width: 980px;">
            <form method="post">
                <input type="hidden" name="courseId" value="@Model.CourseId" />
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Название урока</label>
                        <input class="form-control" asp-for="Input.Name" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Номер урока</label>
                        <input class="form-control" asp-for="Input.NumberLesson" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">video_url</label>
                        <input class="form-control" asp-for="Input.VideoUrl" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">meterials_url</label>
                        <input class="form-control" asp-for="Input.MaterialsUrl" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Описание урока (опционально)</label>
                        <textarea class="form-control" asp-for="Input.LessonDescription" rows="3"></textarea>
                    </div>
                    <div class="col-12">
                        <button class="btn btn-primary" type="submit" onclick="return confirm('Добавить урок?');">
                            Добавить урок
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>

